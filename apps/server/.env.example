# ──────────────────────────────────────────────────────────────────────────────
# LIVENOTE - SERVER ENVIRONMENT VARIABLES
# ──────────────────────────────────────────────────────────────────────────────

# 1. DATABASE
# The PostgreSQL connection string. For local dev, ensure the user and db exist.
# Example: postgres://postgres:password@localhost:5432/livenote
DATABASE_URL=postgres://postgres:password@localhost:5432/livenote

# 2. AUTHENTICATION
# A long, random string used to sign JWTs (e.g., generate with `openssl rand -hex 64`)
JWT_SECRET=super_secret_jwt_key_example

# 3. PORTS
# The port where the Express REST API will run
PORT=3000
# The port where the Hocuspocus WebSocket server will run
HOCUSPOCUS_PORT=1234

# 4. CORS
# The URL of the client application (Vite dev server or production URL)
# Example local: http://localhost:5173
# Example prod: https://livenote-app.vercel.app
CLIENT_URL=http://localhost:5173
