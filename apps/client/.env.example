# ──────────────────────────────────────────────────────────────────────────────
# LIVENOTE - CLIENT ENVIRONMENT VARIABLES
# ──────────────────────────────────────────────────────────────────────────────

# 1. API URL
# The base URL for the Express REST API. 
# For local dev, this can be empty or '/api' as Vite proxies it.
# For production (e.g. Vercel), set this to your backend URL (e.g. https://api.yourdomain.com/api)
VITE_API_URL=/api

# 2. COLLABORATION (WEBSOCKET) URL
# The URL for the Hocuspocus WebSocket server.
# For local dev: ws://localhost:3000/collaboration
# For production: wss://yourdomain.com/collaboration
VITE_COLLAB_URL=ws://localhost:3000/collaboration
